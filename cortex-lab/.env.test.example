# cortex-lab/.env.test.example
# Copy to cortex-lab/.env.test and fill in staging values.
# NEVER commit .env.test — it is gitignored.
#
# Fastest setup: run the token generator:
#   node scripts/generate-test-tokens.js \
#     --base-url https://vantro-flow-backend-staging.up.railway.app \
#     --owner-a your-staging-email@example.com:YourPassword \
#     --owner-b your-second-account@example.com:YourPassword2
#
# Prerequisites:
#   - Two accounts already created and OTP-verified on the staging server.
#   - Staging server must NOT have 'prod' in the URL.

# ── Required ─────────────────────────────────────────────────────────────────

# Staging backend URL (must not contain "prod")
CORTEX_TEST_BASE_URL=https://vantro-flow-backend-staging.up.railway.app

# JWT tokens for two separate staging users (different accounts = cross-tenant test)
CORTEX_TEST_TOKEN_OWNER_A=eyJ...
CORTEX_TEST_TOKEN_OWNER_B=eyJ...

# Must be true to allow live mode seed writes
CORTEX_TEST_DB_ALLOW_WRITE=true

# NODE_ENV must not be "production"
NODE_ENV=development

# ── Optional (DB-level assertions) ───────────────────────────────────────────
# A SEPARATE Supabase project used only for test verification.
# If omitted, auth + cross-tenant HTTP tests still run; DB-level event/audit checks are skipped.
# Must differ from your main SUPABASE_URL (sandbox guard enforces this).
# CORTEX_TEST_SUPABASE_URL=https://your-test-project.supabase.co
# CORTEX_TEST_SUPABASE_KEY=your-test-service-role-key

# ── Safety (keep these as-is) ─────────────────────────────────────────────────
CORTEX_TEST_REQUIRE_NON_PROD=true
# CORTEX_TEST_ALLOW_PROD=I-UNDERSTAND   ← never set this unless you truly mean it
