{
  "name": "cross-business-leak",
  "category": "isolation",
  "description": "User B must never read User A's customers, invoices, ai_actions, promises, scores, or memory. Policy guard must block any AI action that references another tenant's entity.",
  "seed": {
    "user_a": "TEST_USER_A",
    "user_b": "TEST_USER_B",
    "a_customers": [{ "id": "cust-A-1", "name": "Alpha Inc" }],
    "b_customers": [{ "id": "cust-B-1", "name": "Beta Corp" }]
  },
  "commands": [
    {
      "type": "ATTEMPT_READ_AS_B",
      "endpoints": [
        "/api/customers",
        "/api/invoices/TEST_USER_A",
        "/api/ai-actions",
        "/api/cortex/memory",
        "/api/customer-scores",
        "/api/promises"
      ]
    },
    {
      "type": "ATTEMPT_AI_ACTION_CREATE_AS_B_FOR_A",
      "action": {
        "action_type": "SEND_POLITE_REMINDER",
        "customer_id": "cust-A-1",
        "amount": 5000,
        "user_id_in_jwt": "TEST_USER_B"
      }
    }
  ],
  "expected_blocked_actions": [
    {
      "reason_contains": "hallucination",
      "from": "cust-A-1",
      "acting_user": "TEST_USER_B"
    }
  ],
  "expected_policy_decisions_min": 1,
  "expected_events": [],
  "expected_db_changes": {
    "ai_actions": { "should_have_status": "system_blocked" }
  }
}
