{
  "name": "broken-promise",
  "category": "learning",
  "description": "When a promise's date passes without payment the broken-promise cron must mark it broken, emit PROMISE_BROKEN, recalculate score, and create a firm follow-up action.",
  "seed": {
    "user_id": "TEST_USER_A",
    "customers": [
      { "id": "cust-2", "name": "ABC Traders", "phone": "+919999900002" }
    ],
    "promises": [
      {
        "id": "prom-1",
        "customer_id": "cust-2",
        "promised_amount": 7500,
        "promised_date": "2026-05-20",
        "status": "active"
      }
    ]
  },
  "command": {
    "type": "RUN_BROKEN_PROMISE_CHECK",
    "now": "2026-05-29T00:00:00Z"
  },
  "expected_events": ["PROMISE_BROKEN", "CUSTOMER_RISK_UPDATED"],
  "expected_actions_min": 1,
  "expected_action_types": ["SEND_FIRM_REMINDER", "CALL_CUSTOMER", "ESCALATE_TO_OWNER"],
  "expected_db_changes": {
    "promises":        { "status_transition": { "from": "active", "to": "broken" } },
    "customer_scores": { "should_recalc_for": ["cust-2"] }
  }
}
