{
  "name": "vantro-flow-backend",
  "version": "1.0.0",
  "description": "Vantro Flow Express backend — deployed to Railway",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "check": "node --check server.js",
    "security:secrets": "node scripts/security-secret-scan.js",
    "security:secret-rotation": "node scripts/check-secret-rotation.js",
    "security:supply-chain": "npm audit --audit-level=high",
    "security:audit": "npm audit --audit-level=high",
    "security:cross-user": "node scripts/cross-user-security-test.js",
    "security:smoke": "node scripts/security-smoke-test.js",
    "cortex:test":         "node cortex-lab/run.js --mode=static",
    "cortex:test:dry":     "node cortex-lab/run.js --mode=dry-run",
    "cortex:test:live":    "node cortex-lab/run.js --mode=live",
    "cortex:test:redteam": "node cortex-lab/run.js --mode=red-team",
    "cortex:test:all":     "node cortex-lab/run.js --mode=all",
    "cortex:harness:loop": "node cortex-lab/run.js --mode=all --loop",
    "cortex:rust:build":   "cargo build --release -p cortex-core && node scripts/copy-cortex-binary.js",
    "cortex:rust:test":    "cargo test -p cortex-core -- --nocapture",
    "cortex:rust:check":   "cargo check -p cortex-core",
    "cortex:rust:fmt":     "cargo fmt -p cortex-core -- --check",
    "cortex:rust:clippy":  "cargo clippy -p cortex-core -- -D warnings",
    "automation:build":    "cargo build --release -p vantro-automation && node scripts/copy-automation-binary.js",
    "automation:test":     "cargo test -p vantro-automation -- --nocapture",
    "automation:check":    "cargo check -p vantro-automation",
    "automation:start":    "node scripts/start-automation-service.js",
    "automation:dev":      "RUST_LOG=vantro_automation_rs=debug node scripts/start-automation-service.js",
    "rust:test:all":       "cargo test -- --nocapture",
    "rust:build:all":      "cargo build --release",
    "rust:check:all":      "cargo check",
    "perf:test":           "node performance-lab/run.js",
    "test:rust-fallback":  "node scripts/test-rust-automation-fallback.js",
    "staging:migrate":     "node scripts/staging-migrate.js",
    "staging:seed":        "node scripts/staging-seed.js",
    "staging:jwt":         "node scripts/staging-jwt.js",
    "staging:verify-auth": "node scripts/staging-verify-auth.js",
    "staging:setup-supabase": "node scripts/setup-node-staging-supabase.js",
    "staging:create-supabase": "node scripts/create-supabase-staging.js",
    "agents:seed": "node scripts/seed-agent-registry.js",
    "agents:seed:validate": "node scripts/seed-agent-registry.js --validate"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "node-cron": "^3.0.3",
    "pg": "^8.13.3",
    "prom-client": "^15.1.3",
    "razorpay": "^2.9.6",
    "twilio": "^4.23.0",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
