# ============================================
# VANTRO FLOW BACKEND — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ============================================

# ── Supabase ────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here # NEVER commit this
SUPABASE_ANON_KEY=your-anon-key-here                 # Public anon key
SUPABASE_KEY=your-service-role-key                   # Legacy support

# ── Rust Cortex Core ────────────────────────
# Keep false until cargo test + harness passes. Set true only when binary exists.
RUST_CORTEX_CORE_ENABLED=false

# ── Rust Automation Service (Axum sidecar) ──
# Keep false until: automation:build passes, cargo test passes, bootstrap <500ms, harness passes.
RUST_AUTOMATION_API_ENABLED=false
RUST_AUTOMATION_PORT=3002
RUST_AUTOMATION_BASE_URL=http://localhost:3002
RUST_LOG=vantro_automation_rs=info,tower_http=warn

# ── Event / Workflow infrastructure (optional) ──
# NATS_URL=nats://localhost:4222
# TEMPORAL_HOST=localhost:7233
# REDIS_URL=redis://localhost:6379

# ── Auth ────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-string  # REQUIRED — generate: openssl rand -hex 32

# ── Environment ─────────────────────────────
NODE_ENV=development                           # Keep development for local/test
TEST_MODE=true                                 # Set to true for Cortex tests
CORTEX_TEST_MODE=true                          # Enables test-only endpoints like auth-test

# ── Database (Supabase Direct Postgres) ────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Get from: Supabase → Settings → Database → Connection String → URI

# ── AI / LLM ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Scanner fallback order. Default: groq,gemini,openrouter,huggingface,ocrspace
SCAN_AI_PROVIDERS=groq,gemini,openrouter,huggingface,ocrspace
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GEMINI_API_KEY=...
GEMINI_VISION_MODEL=gemini-3.5-flash
OPENROUTER_API_KEY=...
OPENROUTER_VISION_MODELS=qwen/qwen2.5-vl-72b-instruct:free,qwen/qwen2.5-vl-32b-instruct:free
HF_TOKEN=...
HF_VISION_MODEL=zai-org/GLM-4.5V
OCRSPACE_API_KEY=helloworld

# ── Payments (Razorpay) ─────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ── Push Notifications (VAPID) ──────────────
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=hello@vantroflow.com
# Generate: npx web-push generate-vapid-keys

# ── Twilio (Voice Calls) ────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxx
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── WhatsApp ─────────────────────────────────
# Per-user WhatsApp credentials stored in DB (set via /api/settings/twilio)
# These are NOT server-level env vars

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=https://vantroflow.com,https://www.vantroflow.com
# Vercel preview URLs (*.vercel.app) are allowed automatically

# ── Server ───────────────────────────────────
PORT=3001
NODE_ENV=production
