# ============================================
# VANTRO FLOW BACKEND — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ============================================

# ── Supabase ────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key         # Use service_role key for backend (not anon)

# ── Auth ────────────────────────────────────
JWT_SECRET=replace-with-64-char-random-string  # REQUIRED — generate: openssl rand -hex 32

# ── Database (Supabase Direct Postgres) ────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Get from: Supabase → Settings → Database → Connection String → URI

# ── AI / LLM ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# ── Payments (Razorpay) ─────────────────────
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# ── Push Notifications (VAPID) ──────────────
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_EMAIL=hello@vantroflow.com
# Generate: npx web-push generate-vapid-keys

# ── Twilio (Voice Calls) ────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxx
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ── WhatsApp ─────────────────────────────────
# Per-user WhatsApp credentials stored in DB (set via /api/settings/twilio)
# These are NOT server-level env vars

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=https://vantroflow.com,https://www.vantroflow.com
# Vercel preview URLs (*.vercel.app) are allowed automatically

# ── Server ───────────────────────────────────
PORT=3001
NODE_ENV=production
